{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Code Review",
      "type": "shell",
      "command": "gh copilot explain",
      "args": ["${file}"],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Generate Documentation",
      "type": "shell",
      "command": "bash automation/doc_gen.sh ${file}",
      "group": "build",
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}