{
  "openapi": "3.0.3",
  "info": {
    "title": "StockSync API",
    "version": "1.1.0",
    "description": "Multi-channel inventory management and analytics API."
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "InventoryItem": {
        "type": "object",
        "required": ["sku", "name"],
        "properties": {
          "sku": { "type": "string" },
          "name": { "type": "string" },
          "total_stock": { "type": "integer" },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "platform": { "type": "string" },
                "stock": { "type": "integer" }
              }
            }
          }
        }
      },
      "BulkUpdateItem": {
        "type": "object",
        "required": ["sku", "adjustment"],
        "properties": {
          "sku": { "type": "string" },
          "adjustment": { "type": "integer" }
        }
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {
    "/inventory": {
      "get": { "summary": "1. READ (List)" },
      "post": { "summary": "2. CREATE" }
    },
    "/inventory/{sku}": {
      "get": { "summary": "3. READ (Detail)" },
      "patch": { "summary": "4. UPDATE" },
      "delete": { "summary": "5. DELETE" }
    },
    "/inventory/bulk": {
      "put": {
        "summary": "6. BULK UPDATE",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": { "$ref": "#/components/schemas/BulkUpdateItem" }
              }
            }
          }
        },
        "responses": { "200": { "description": "Success" } }
      }
    }
  }
}